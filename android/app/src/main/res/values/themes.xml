<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.CatTogether" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/nav_header_background</item>
        <item name="colorPrimaryDark">@color/nav_header_background</item>
        <item name="colorAccent">@color/nav_header_background</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/status_bar_background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/background_page</item>
        <item name="android:colorBackground">@color/background_page</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Action bar -->
        <item name="actionBarStyle">@style/CatTogetherActionBar</item>
    </style>

    <style name="Theme.CatTogether.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.CatTogether.Transparent">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="CatTogetherActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/background_page</item>
        <item name="elevation">0dp</item>
        <item name="android:titleTextStyle">@style/CatTogetherActionBarTitle</item>
    </style>

    <style name="CatTogetherActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- EditText style -->
    <style name="CatTogetherEditText" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/nav_header_background</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Button styles -->
    <style name="CatTogetherButton" parent="Widget.AppCompat.Button">
        <item name="backgroundTint">@color/nav_header_background</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="CatTogetherButton.Outline" parent="Widget.AppCompat.Button.Borderless">
        <item name="strokeColor">@color/nav_header_background</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textColor">@color/nav_header_background</item>
    </style>
</resources>
