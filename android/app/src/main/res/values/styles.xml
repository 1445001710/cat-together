<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 现代化底部导航栏样式 -->
    <style name="ModernBottomNav" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemBackground">@android:color/transparent</item>
        <item name="elevation">0dp</item>
        <item name="itemIconSize">24dp</item>
        <item name="itemTextAppearanceActive">@style/BottomNavTextActive</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavTextInactive</item>
        <item name="itemRippleColor">@color/nav_gradient_start</item>
    </style>

    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <!-- 顶部导航栏样式 -->
    <style name="ModernTopNav">
        <item name="android:background">@drawable/nav_gradient_background</item>
        <item name="android:elevation">0dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="ModernTopNavTitle">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- 现代化搜索框样式 -->
    <style name="ModernSearchBox">
        <item name="android:background">@drawable/search_box_background</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:hint">@string/search_cats_hint</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:drawableStart">@drawable/ic_search</item>
        <item name="android:drawablePadding">12dp</item>
        <item name="android:imeOptions">actionSearch</item>
        <item name="android:inputType">text</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- 现代化卡片样式 -->
    <style name="ModernCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- 猫咪卡片样式 -->
    <style name="CatCard">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- 快捷功能卡片样式 -->
    <style name="FeatureCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- 圆形按钮样式 -->
    <style name="CircleButton">
        <item name="cornerRadius">28dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- 现代化按钮样式 -->
    <style name="ModernPrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:elevation">0dp</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- 次要按钮样式 -->
    <style name="ModernSecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- 浮动按钮样式 -->
    <style name="ModernFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/text_primary</item>
        <item name="fabSize">normal</item>
        <item name="tint">@color/white</item>
        <item name="elevation">6dp</item>
        <item name="hoveredFocusedTranslationZ">8dp</item>
        <item name="pressedTranslationZ">12dp</item>
    </style>

</resources>
