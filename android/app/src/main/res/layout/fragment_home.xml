<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="100dp">

            <!-- 横向卡片区域 -->
            <HorizontalScrollView
                android:id="@+id/horizontalCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 今日推荐卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardDaily"
                        android:layout_width="160dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/background_card"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivDailyImage"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:scaleType="centerCrop"
                                android:background="@color/background_card"
                                android:src="@drawable/index_style_1" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="今日推荐"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 领养信息卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAdopt"
                        android:layout_width="160dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/background_card"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivAdoptImage"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:scaleType="centerCrop"
                                android:background="@color/background_card"
                                android:src="@drawable/index_style_2" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="领养信息"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- 猫咪日记卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardDiary"
                        android:layout_width="160dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/background_card"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/ivDiaryImage"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:scaleType="centerCrop"
                                android:background="@color/background_card"
                                android:src="@drawable/index_style_3" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="猫咪日记"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- 我的猫咪标题 -->
            <TextView
                android:id="@+id/tvMyCatsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="我的猫咪"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 猫咪列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_cat_card"
                tools:itemCount="3" />

            <!-- 空状态 -->
            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:alpha="0.4"
                    android:src="@mipmap/ic_launcher" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/no_cat"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnAddFirstCat"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="24dp"
                    android:minWidth="120dp"
                    android:text="@string/add_first_cat"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:background="@drawable/button_primary_background" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddCat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="添加猫咪"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary_pink"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>